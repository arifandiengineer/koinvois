<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera is used optionally (attach photo to invoice/estimate, business logo);
         required="false" so the app stays installable on camera-less devices (e.g. some tablets). -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <!-- TODO(core/pdf sprint): WRITE_EXTERNAL_STORAGE + requestLegacyExternalStorage are already
         inert on API 30+ under targetSdk 35; PDF export/share file I/O needs a scoped-storage /
         FileProvider audit before these can be removed. See Migration Notes, Sprint 1 report. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name="com.koinvois.generator.ApplicationClass"
        android:allowBackup="false"
        android:allowClearUserData="true"
        android:enableOnBackInvokedCallback="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.App.Starting">
        <activity
            android:name="com.koinvois.generator.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.koinvois.generator.ui.client.ClientMainActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.client.add_client.AddClientActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.item.ItemMainActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.item.add_item.AddItemActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.setting.SettingActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.setting.add_business.AddBusinessDetailsActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.lock.EnterPasswordActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.lock.LockMainActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.lock.SavePasswordActivity"
            android:theme="@style/Theme.InvoiceMaker"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.koinvois.generator.provider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/paths" />
        </provider>
    </application>

</manifest>