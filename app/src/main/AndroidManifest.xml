<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name="com.koinvois.generator.ApplicationClass"
        android:allowBackup="false"
        android:allowClearUserData="true"
        android:enableOnBackInvokedCallback="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.App.Starting">
        <activity
            android:name="com.koinvois.generator.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.koinvois.generator.ui.client.ClientMainActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.client.add_client.AddClientActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.item.ItemMainActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.item.add_item.AddItemActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.setting.SettingActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.setting.add_business.AddBusinessDetailsActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.lock.EnterPasswordActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.lock.LockMainActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.lock.SavePasswordActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
            android:name="com.koinvois.generator.ui.invoices.add_invoice.AddInvoiceMainActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />
        <activity
