        <activity
            android:name="com.koinvois.generator.ui.notifications.NotificationsActivity"
            android:theme="@style/Theme.Koinvois"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.koinvois.generator.provider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/paths" />
        </provider>

        <!-- Lets AppCompatDelegate.setApplicationLocales persist the chosen
             language across process death on API < 33 (framework LocaleManager
             handles it natively on 33+). Required for the per-app language API. -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>