<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.client.add_client.AddClientActivity">

    <include
        android:id="@+id/customToolbar"
        layout="@layout/view_custom_toolbar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_80"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/customToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <!-- Card 1: Client Information -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/firstCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_circle_blue"
                            android:padding="10dp"
                            android:src="@drawable/ic_user_outline"
                            app:tint="@color/color_stat_blue" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_client_information"
                                android:textColor="@color/color_text_primary"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_add_or_edit_client_info"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="@dimen/text_size_11" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Client Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_20"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_user_outline"
                            app:tint="@color/color_icon_grey_medium" />

                        <EditText
                            android:id="@+id/editClientName"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_client_name"
                            android:inputType="textPersonName"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_mail_outline"
                            app:tint="@color/color_icon_grey_medium" />

                        <EditText
                            android:id="@+id/editClientEmail"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_email"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Mobile -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_label_box"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/spacing_12">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/color_stat_blue" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_8"
                                android:text="@string/label_mobile"
                                android:textColor="@color/color_text_primary"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/editMobileNumber"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_border"
                            android:hint="@string/hint_mobile_number"
                            android:inputType="phone"
                            android:paddingHorizontal="@dimen/spacing_12"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Phone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_label_box"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/spacing_12">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/color_stat_blue" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_8"
                                android:text="@string/label_phone_colon"
                                android:textColor="@color/color_text_primary"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/editPhoneNumber"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_border"
                            android:hint="@string/hint_phone_number"
                            android:inputType="phone"
                            android:paddingHorizontal="@dimen/spacing_12"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Fax -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_label_box"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="@dimen/spacing_12">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_fax_outline"
                                app:tint="@color/color_stat_blue" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_8"
                                android:text="@string/label_fax"
                                android:textColor="@color/color_text_primary"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/editFaxNumber"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_border"
                            android:hint="@string/hint_fax_number"
                            android:inputType="phone"
                            android:paddingHorizontal="@dimen/spacing_12"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Contact/Address -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/secondCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_circle_green"
                            android:padding="10dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/color_success" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/more_menu_client"
                                android:textColor="@color/color_text_primary"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_enter_client_address"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="@dimen/text_size_11" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Contact Person -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_20"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_business"
                            app:tint="@color/color_icon_grey_medium" />

                        <EditText
                            android:id="@+id/editContact"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_contact"
                            android:inputType="textPersonName"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Address 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_home_outline"
                            app:tint="@color/color_icon_grey_medium" />

                        <EditText
                            android:id="@+id/editAddress1"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_address_1"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Address 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_home_outline"
                            app:tint="@color/color_icon_grey_medium" />

                        <EditText
                            android:id="@+id/editAddress2"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_address_2"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <!-- Address 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_home_outline"
                            app:tint="@color/color_icon_grey_medium" />

                        <EditText
                            android:id="@+id/editAddress3"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_address_3"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveClient"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="@dimen/spacing_16"
        android:backgroundTint="@color/color_success"
        android:text="@string/label_save_client"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_16"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_save"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/spacing_8"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
