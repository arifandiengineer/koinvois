<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.estimates.add_estimate.sub_fragments.estimate_edit_fragments.ItemDetailForEstimateActivity">

    <include
        android:id="@+id/customToolbar"
        layout="@layout/view_custom_toolbar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/customToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Card 1: Item Information -->
            <androidx.cardview.widget.CardView
                android:id="@+id/firstCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:id="@+id/imgItemInfoIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_circle_orange"
                        android:padding="6dp"
                        android:src="@drawable/ic_item_details"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/color_stat_orange" />

                    <TextView
                        android:id="@+id/lblItemInformation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/label_business_info"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgItemInfoIcon"
                        app:layout_constraintStart_toEndOf="@id/imgItemInfoIcon"
                        app:layout_constraintTop_toTopOf="@id/imgItemInfoIcon" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputItemDescription"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_20"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/imgItemInfoIcon"
                        app:startIconDrawable="@drawable/ic_document_text"
                        app:startIconTint="@color/color_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editItemDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_description"
                            android:textSize="@dimen/text_size_14" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Unit Cost Row -->
                    <ImageView
                        android:id="@+id/imgUnitCostIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:background="@drawable/bg_icon_circle_gold"
                        android:padding="8dp"
                        android:src="@drawable/ic_unit_cost"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/inputItemDescription"
                        app:tint="@color/color_stat_orange" />

                    <TextView
                        android:id="@+id/txtItemUnitCost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/label_unit_cost"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgUnitCostIcon"
                        app:layout_constraintStart_toEndOf="@id/imgUnitCostIcon"
                        app:layout_constraintTop_toTopOf="@id/imgUnitCostIcon" />

                    <EditText
                        android:id="@+id/editItemUnitCost"
                        android:layout_width="140dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_border"
                        android:gravity="end|center_vertical"
                        android:hint="@string/label_default_amount"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        app:layout_constraintBottom_toBottomOf="@id/imgUnitCostIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/imgUnitCostIcon" />

                    <!-- Quantity Row -->
                    <ImageView
                        android:id="@+id/imgQuantityIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:background="@drawable/bg_icon_circle_blue"
                        android:padding="8dp"
                        android:src="@drawable/ic_calendar"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgUnitCostIcon"
                        app:tint="@color/color_stat_blue" />

                    <TextView
                        android:id="@+id/txtQuantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/dashboard_add_item"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgQuantityIcon"
                        app:layout_constraintStart_toEndOf="@id/imgQuantityIcon"
                        app:layout_constraintTop_toTopOf="@id/imgQuantityIcon" />

                    <EditText
                        android:id="@+id/editQuantity"
                        android:layout_width="140dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_border"
                        android:gravity="end|center_vertical"
                        android:hint="@string/hint_quantity_default"
                        android:inputType="number"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        app:layout_constraintBottom_toBottomOf="@id/imgQuantityIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/imgQuantityIcon" />

                    <!-- Discount Row -->
                    <ImageView
                        android:id="@+id/imgDiscountIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:background="@drawable/bg_icon_circle_purple"
                        android:padding="8dp"
                        android:src="@drawable/ic_wallet"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgQuantityIcon"
                        app:tint="@color/color_stat_purple" />

                    <TextView
                        android:id="@+id/txtDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/label_discount"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgDiscountIcon"
                        app:layout_constraintStart_toEndOf="@id/imgDiscountIcon"
                        app:layout_constraintTop_toTopOf="@id/imgDiscountIcon" />

                    <TextView
                        android:id="@+id/txtItemDiscountType"
                        android:layout_width="140dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_border"
                        android:gravity="center_vertical|start"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:text="@string/bs_discount_percentage"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        app:drawableEndCompat="@drawable/btn_forward"
                        app:layout_constraintBottom_toBottomOf="@id/imgDiscountIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/imgDiscountIcon" />

                    <!-- Discount Amount Row -->
                    <ImageView
                        android:id="@+id/imgDiscountAmountIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:background="@drawable/bg_icon_circle_orange"
                        android:padding="8dp"
                        android:src="@drawable/ic_unit_cost"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgDiscountIcon"
                        app:tint="@color/color_stat_orange" />

                    <TextView
                        android:id="@+id/txtDiscountAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/label_discount_amount"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgDiscountAmountIcon"
                        app:layout_constraintStart_toEndOf="@id/imgDiscountAmountIcon"
                        app:layout_constraintTop_toTopOf="@id/imgDiscountAmountIcon" />

                    <EditText
                        android:id="@+id/editDiscountAmount"
                        android:layout_width="140dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_border"
                        android:gravity="end|center_vertical"
                        android:hint="@string/hint_percentage_default"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        app:layout_constraintBottom_toBottomOf="@id/imgDiscountAmountIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/imgDiscountAmountIcon" />

                    <!-- Taxable Row -->
                    <ImageView
                        android:id="@+id/imgTaxableIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:background="@drawable/bg_icon_circle_green"
                        android:padding="8dp"
                        android:src="@drawable/ic_taxable"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgDiscountAmountIcon"
                        app:tint="@color/color_success" />

                    <TextView
                        android:id="@+id/txtItemTaxable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/label_taxable"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgTaxableIcon"
                        app:layout_constraintStart_toEndOf="@id/imgTaxableIcon"
                        app:layout_constraintTop_toTopOf="@id/imgTaxableIcon" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchItemTaxable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:layout_constraintBottom_toBottomOf="@id/imgTaxableIcon"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/imgTaxableIcon" />

                    <!-- Tax Rate (Optional Row) -->
                    <TextView
                        android:id="@+id/txtTax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:text="@string/label_tax_rate_percent"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgTaxableIcon" />

                    <EditText
                        android:id="@+id/editTaxRate"
                        android:layout_width="140dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_border"
                        android:gravity="end|center_vertical"
                        android:hint="@string/hint_percentage_default"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_14"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="@id/txtTax"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/txtTax" />

                    <androidx.constraintlayout.widget.Group
                        android:id="@+id/groupTaxRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:constraint_referenced_ids="txtTax,editTaxRate" />

                    <!-- Total Section -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/totalSection"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:background="@drawable/shape_rounded_12dp"
                        android:backgroundTint="@color/color_primary"
                        app:layout_constraintTop_toBottomOf="@id/editTaxRate">

                        <TextView
                            android:id="@+id/txtTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_total"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/txtTotalBalanceAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_16"
                            tools:text="$0.00"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_size_18"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Additional Details -->
            <androidx.cardview.widget.CardView
                android:id="@+id/secondCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/firstCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:id="@+id/imgAdditionalDetailsIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_circle_blue"
                        android:padding="6dp"
                        android:src="@drawable/ic_additional_details"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/color_stat_blue" />

                    <TextView
                        android:id="@+id/lblAdditionalDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/title_items"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/imgAdditionalDetailsIcon"
                        app:layout_constraintStart_toEndOf="@id/imgAdditionalDetailsIcon"
                        app:layout_constraintTop_toTopOf="@id/imgAdditionalDetailsIcon" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputItemDetails"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_20"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/imgAdditionalDetailsIcon">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editItemDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="start|top"
                            android:hint="@string/hint_additional_details"
                            android:lines="5"
                            android:textSize="@dimen/text_size_14" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/txtDetailsCharCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        tools:text="0 / 500"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_size_12"
                        app:layout_constraintEnd_toEndOf="@id/inputItemDetails"
                        app:layout_constraintTop_toBottomOf="@id/inputItemDetails" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
