<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.invoices.add_invoice.invoice_edit_fragments.AddPhotoToInvoiceActivity">

    <include
        android:id="@+id/customToolbar"
        layout="@layout/view_custom_toolbar"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/md_theme_primary"
        android:insetBottom="0dp"
        android:insetTop="0dp"
        android:text="@string/action_save"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_16"
        android:textStyle="bold"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnSave"
        app:layout_constraintTop_toBottomOf="@id/customToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <!-- Photo Upload Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddPhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_margin="@dimen/spacing_12"
                    android:background="@drawable/bg_dashed_border">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/imgPhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_add_photo_placeholder"
                                android:contentDescription="@string/cd_add_photo" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_12"
                            android:text="@string/label_add_photo"
                            android:textColor="@color/color_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_tap_to_select_photo"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Details Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_16">

                    <!-- Description Header Section -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconDescriptionContainer"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="@color/color_stat_green_bg"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/imgHeaderDescription"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_document_text"
                            app:tint="@color/color_success"
                            android:contentDescription="@null" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/titleDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/hint_description"
                        android:textColor="@color/color_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/iconDescriptionContainer"
                        app:layout_constraintStart_toEndOf="@id/iconDescriptionContainer"
                        app:layout_constraintTop_toTopOf="@id/iconDescriptionContainer" />

                    <EditText
                        android:id="@+id/editPhotoDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:hint="@string/hint_enter_description"
                        android:inputType="text"
                        android:padding="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="16sp"
                        app:layout_constraintTop_toBottomOf="@id/iconDescriptionContainer" />

                    <!-- Divider -->
                    <View
                        android:id="@+id/detailsDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/spacing_20"
                        android:background="@color/color_divider"
                        app:layout_constraintTop_toBottomOf="@id/editPhotoDescription" />

                    <!-- Additional Details Header Section -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconAdditionalContainer"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginTop="@dimen/spacing_20"
                        app:cardBackgroundColor="@color/color_stat_green_bg"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/detailsDivider">

                        <ImageView
                            android:id="@+id/imgHeaderAdditionalDetails"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_additional_details"
                            app:tint="@color/color_success"
                            android:contentDescription="@null" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/titleAdditionalDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/hint_additional_details"
                        android:textColor="@color/color_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/iconAdditionalContainer"
                        app:layout_constraintStart_toEndOf="@id/iconAdditionalContainer"
                        app:layout_constraintTop_toTopOf="@id/iconAdditionalContainer" />

                    <EditText
                        android:id="@+id/editAdditionalDetails"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:gravity="top"
                        android:hint="@string/hint_enter_additional_details"
                        android:inputType="textMultiLine"
                        android:padding="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="16sp"
                        app:layout_constraintTop_toBottomOf="@id/iconAdditionalContainer" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>