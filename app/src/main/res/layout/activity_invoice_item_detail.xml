<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.invoices.add_invoice.invoice_edit_fragments.ItemDetailForInvoiceActivity">

    <include
        android:id="@+id/customToolbar"
        layout="@layout/view_custom_toolbar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/customToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <!-- Primary Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/firstCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <!-- Description Input Section -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/descriptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_border"
                        android:padding="@dimen/spacing_12">

                        <ImageView
                            android:id="@+id/imgDescIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_document_text"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/color_success" />

                        <EditText
                            android:id="@+id/editItemDescription"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:background="@null"
                            android:hint="@string/hint_description"
                            android:inputType="text"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/imgDescIcon"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Row: Unit Cost -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_8">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconUnitCostContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:padding="8dp"
                                android:src="@drawable/ic_wallet"
                                app:tint="@color/color_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/txtItemUnitCost"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_unit_cost"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/editItemUnitCost"
                            app:layout_constraintStart_toEndOf="@id/iconUnitCostContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <EditText
                            android:id="@+id/editItemUnitCost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:gravity="end"
                            android:hint="@string/label_default_amount"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_success"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_divider" />

                    <!-- Row: Quantity -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_8">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconQtyContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:padding="8dp"
                                android:src="@drawable/ic_onboarding_organized"
                                app:tint="@color/color_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/txtQuantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_quantity_colon"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/editQuantity"
                            app:layout_constraintStart_toEndOf="@id/iconQtyContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <EditText
                            android:id="@+id/editQuantity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:gravity="end"
                            android:hint="@string/hint_quantity_default"
                            android:inputType="number"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_divider" />

                    <!-- Row: Discount Type -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_8">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconDiscountContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:padding="8dp"
                                android:src="@drawable/ic_percent"
                                app:tint="@color/color_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/txtDiscount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_discount"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/txtItemDiscountType"
                            app:layout_constraintStart_toEndOf="@id/iconDiscountContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/txtItemDiscountType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="@string/label_percentage"
                            android:textColor="@color/color_success"
                            android:textSize="@dimen/text_size_16"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_divider" />

                    <!-- Row: Discount Amount -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_8">

                        <TextView
                            android:id="@+id/textView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="outstanding_invoices" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconDiscountAmtContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:padding="8dp"
                                android:src="@drawable/ic_taxable"
                                app:tint="@color/color_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/txtDiscountAmount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_discount_amount"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/editDiscountAmount"
                            app:layout_constraintStart_toEndOf="@id/iconDiscountAmtContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <EditText
                            android:id="@+id/editDiscountAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:gravity="end"
                            android:hint="@string/hint_percentage_default"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_success"
                            android:textSize="@dimen/text_size_16"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_divider" />

                    <!-- Row: Taxable -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_8">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconTaxableContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:padding="8dp"
                                android:src="@drawable/ic_document_text"
                                app:tint="@color/color_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/txtItemTaxable"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_taxable_colon"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/switchItemTaxable"
                            app:layout_constraintStart_toEndOf="@id/iconTaxableContainer"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchItemTaxable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Tax Rate (Optional Row, hidden if not taxable) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/groupTaxRateRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:paddingVertical="@dimen/spacing_8">

                        <View
                            android:id="@+id/taxRateDivider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/color_divider"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/iconTaxRateContainer"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginTop="@dimen/spacing_8"
                            app:cardBackgroundColor="@color/color_stat_green_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/taxRateDivider">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:padding="8dp"
                                android:src="@drawable/ic_percent"
                                app:tint="@color/color_success" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/txtTax"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_16"
                            android:text="@string/label_tax_rate_colon"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_size_16"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/editTaxRate"
                            app:layout_constraintStart_toEndOf="@id/iconTaxRateContainer"
                            app:layout_constraintTop_toTopOf="@id/iconTaxRateContainer" />

                        <EditText
                            android:id="@+id/editTaxRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:gravity="end"
                            android:hint="@string/hint_percentage_default"
                            android:inputType="numberDecimal"
                            android:textColor="@color/color_success"
                            android:textSize="@dimen/text_size_16"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/iconTaxRateContainer" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Total Section -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_16"
                        android:background="@drawable/bg_translucent_card"
                        android:backgroundTint="@color/color_stat_green_bg"
                        android:padding="@dimen/spacing_12">

                        <TextView
                            android:id="@+id/txtTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_total_colon"
                            android:textColor="@color/color_success"
                            android:textSize="@dimen/text_size_18"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/txtTotalBalanceAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="$0.00"
                            android:textColor="@color/color_success"
                            android:textSize="@dimen/text_size_18"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Additional Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/secondCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_16">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/iconDetailsContainer"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="@color/color_stat_green_bg"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:padding="8dp"
                            android:src="@drawable/ic_additional_details"
                            app:tint="@color/color_success" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/titleDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:text="@string/hint_additional_details"
                        android:textColor="@color/color_success"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/iconDetailsContainer"
                        app:layout_constraintStart_toEndOf="@id/iconDetailsContainer"
                        app:layout_constraintTop_toTopOf="@id/iconDetailsContainer" />

                    <EditText
                        android:id="@+id/editItemDetails"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@drawable/bg_input_border"
                        android:gravity="top"
                        android:hint="@string/hint_enter_additional_details"
                        android:inputType="textMultiLine"
                        android:padding="@dimen/spacing_12"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_size_16"
                        app:layout_constraintTop_toBottomOf="@id/iconDetailsContainer" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>