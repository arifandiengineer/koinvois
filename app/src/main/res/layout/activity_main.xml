<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Header Section (At the top) -->
    <RelativeLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dashboard_header"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/view_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_16"
            android:layout_marginVertical="@dimen/spacing_16"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgSetting"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/shape_rounded_12dp"
                android:backgroundTint="@color/white"
                android:contentDescription="@string/cd_settings"
                android:elevation="2dp"
                android:padding="@dimen/spacing_8"
                android:src="@drawable/icon_setting" />

            <LinearLayout
                android:id="@+id/greetingContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_16"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_greeting"
                    android:textColor="@color/color_translucent_white_text"
                    android:textSize="@dimen/text_size_14" />

                <TextView
                    android:id="@+id/txtMainTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_dashboard"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_22"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </RelativeLayout>

    <!-- Fragment Host (Fills middle space) -->
    <fragment
        android:id="@+id/nav_host_fragment_activity_main"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/navView"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:navGraph="@navigation/mobile_navigation" />

    <!-- Bottom Navigation (At the bottom) -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="16dp"
        app:itemActiveIndicatorStyle="@style/App.ActiveIndicator"
        app:itemIconTint="@color/tab_icon_selector"
        app:itemTextColor="@color/tab_icon_selector"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

    <!-- Original Toolbar hidden -->
    <include
        android:id="@+id/customToolbar"
        layout="@layout/view_custom_toolbar"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
