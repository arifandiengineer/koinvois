<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.invoices.add_invoice.invoice_edit_fragments.DiscountActivity">

    <include
        android:id="@+id/customToolbar"
        layout="@layout/view_custom_toolbar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/firstCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_30"
        android:layout_marginTop="@dimen/spacing_40"
        app:cardCornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/customToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/txtDiscountType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/spacing_20"
                android:paddingStart="@dimen/spacing_14"
                android:text="@string/discount_label_discount"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_16"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.5" />

            <TextView
                android:id="@+id/editDiscountType"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@null"
                android:gravity="end|center_vertical"
                android:hint="@string/hint_no_discount"
                android:paddingEnd="@dimen/spacing_14"
                android:textColor="@color/black"
                android:textColorHint="@color/dim_text_color"
                android:textSize="@dimen/text_size_16"
                app:layout_constraintBottom_toBottomOf="@+id/txtDiscountType"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/txtDiscountType"
                app:layout_constraintWidth_percent="0.5" />

            <TextView
                android:id="@+id/txtDiscountAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_20"
                android:paddingStart="@dimen/spacing_14"
                android:text="@string/discount_label_amount"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_16"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/txtDiscountType"
                app:layout_constraintStart_toStartOf="@+id/txtDiscountType"
                app:layout_constraintTop_toBottomOf="@+id/editDiscountType" />

            <EditText
                android:id="@+id/editDiscountAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@null"
                android:gravity="end"
                android:hint="@string/hint_zero_decimal_default"
                android:inputType="number"
                android:paddingEnd="@dimen/spacing_14"
                android:textColor="@color/black"
                android:textColorHint="@color/dim_text_color"
                android:textSize="@dimen/text_size_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/editDiscountType"
                app:layout_constraintTop_toTopOf="@id/txtDiscountAmount" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/discountAmountGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="txtDiscountAmount,editDiscountAmount" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>