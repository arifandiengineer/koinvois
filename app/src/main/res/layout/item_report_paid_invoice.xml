<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingVertical="@dimen/spacing_12">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/avatarContainer"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="@dimen/spacing_16"
        app:cardBackgroundColor="@color/color_stat_green_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtInitials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/color_success"
            android:textSize="@dimen/text_size_10"
            android:textStyle="bold"
            tools:text="AC" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txtClientName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_12"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/text_size_10"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtInvoiceId"
        app:layout_constraintHorizontal_weight="0.4"
        app:layout_constraintStart_toEndOf="@id/avatarContainer"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Acme Corporation" />

    <TextView
        android:id="@+id/txtInvoiceDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/color_text_secondary"
        android:textSize="9sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtAmount"
        app:layout_constraintHorizontal_weight="0.3"
        app:layout_constraintStart_toEndOf="@id/txtInvoiceId"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="May 20, 2024" />

    <!-- We keep txtInvoiceId for logic but hide it to match new simplified report view if needed,
         or we can use it to show invoice number as per weight -->
    <TextView
        android:id="@+id/txtInvoiceId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/txtInvoiceDate"
        app:layout_constraintStart_toEndOf="@id/txtClientName"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:layout_marginEnd="@dimen/spacing_16"
        android:textColor="@color/color_success"
        android:textSize="@dimen/text_size_10"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="0.3"
        app:layout_constraintStart_toEndOf="@id/txtInvoiceDate"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="$850.00" />

</androidx.constraintlayout.widget.ConstraintLayout>