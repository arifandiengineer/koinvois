<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/spacing_16"
    android:paddingTop="@dimen/spacing_12">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_16">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/avatarContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="@color/color_stat_green_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/imgClientAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_user_outline"
                    app:tint="@color/color_success"
                    android:contentDescription="@null" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtClientName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_16"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/txtAmount"
                app:layout_constraintStart_toEndOf="@id/avatarContainer"
                app:layout_constraintTop_toTopOf="@id/avatarContainer"
                tools:text="Client Name" />

            <TextView
                android:id="@+id/txtInvoiceDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_size_12"
                app:layout_constraintEnd_toEndOf="@id/txtClientName"
                app:layout_constraintStart_toStartOf="@id/txtClientName"
                app:layout_constraintTop_toBottomOf="@id/txtClientName"
                tools:text="Number of invoices" />

            <TextView
                android:id="@+id/txtAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_success"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/txtClientName"
                tools:text="0.00$" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardBackgroundColor="@color/color_stat_green_bg"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtAmount">

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="Paid"
                    android:textAllCaps="false"
                    android:textColor="@color/color_success"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Keep initials for backward compatibility if logic needs it, hidden from UI -->
            <TextView
                android:id="@+id/txtInitials"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Keep txtInvoiceId for backward compatibility -->
            <TextView
                android:id="@+id/txtInvoiceId"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>