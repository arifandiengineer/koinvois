<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/transparentColor">

    <TextView
        android:id="@+id/txrToolbarTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/white"
        android:textAppearance="@style/TextAppearance.App.Toolbar"
        app:layout_constraintBottom_toBottomOf="@+id/imgSetting"
        app:layout_constraintEnd_toStartOf="@+id/imgSearch"
        app:layout_constraintStart_toEndOf="@+id/imgSetting"
        app:layout_constraintTop_toTopOf="@+id/imgSetting" />

    <ImageView
        android:id="@+id/imgSetting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_16"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:scaleType="center"
        android:src="@drawable/icon_setting"
        android:contentDescription="@string/cd_settings"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_16"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:scaleType="center"
        android:src="@drawable/icon_back"
        android:contentDescription="@string/cd_back"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_32"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:scaleType="center"
        android:src="@drawable/icon_search"
        android:contentDescription="@string/cd_search"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_32"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:scaleType="center"
        android:src="@drawable/btn_delete"
        android:contentDescription="@string/cd_delete"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgThreeDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_32"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:scaleType="center"
        android:src="@drawable/icon_three_dot"
        android:contentDescription="@string/cd_more_options"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgRefresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_32"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:scaleType="center"
        android:src="@drawable/icon_referesh"
        android:contentDescription="@string/cd_refresh"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>