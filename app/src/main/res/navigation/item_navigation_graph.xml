<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_navigation_graph"
    app:startDestination="@id/fragmentMainItem">


    <fragment
        android:id="@+id/fragmentMainItem"
        android:name="com.koinvois.generator.ui.item.ItemMainFragment"
        tools:layout="@layout/item_main_fragment">
        <action
            android:id="@+id/actionMainItemFragmentToAddItemFragment"
            app:destination="@id/fragmentAddItem" />
    </fragment>

    <fragment
        android:id="@+id/fragmentAddItem"
        android:name="com.koinvois.generator.ui.item.add_item.AddItemFragment"
        tools:layout="@layout/fragment_add_item">
        <argument
            android:name="item_type"
            app:argType="string" />
    </fragment>
</navigation>