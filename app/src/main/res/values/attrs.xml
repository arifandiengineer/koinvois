        <attr name="android:hint" />
        <attr name="android:inputType" />
        <attr name="inputIcon" format="reference" />
        <attr name="isLabelMode" format="boolean" />
    </declare-styleable>

    <declare-styleable name="KoinvoisLabel">
        <attr name="android:text" />
