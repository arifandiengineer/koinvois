    <declare-styleable name="BusinessInputView">
        <attr name="inputIcon" />
        <attr name="inputIconTint" format="color" />
        <attr name="inputLabel" format="string" />
        <attr name="inputHint" format="string" />
        <attr name="android:inputType" />
    </declare-styleable>
</resources>
